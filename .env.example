# ============================================================
# PendleAPYito (PAO) — Template de configuration
# Copie ce fichier en ".env" puis remplis les valeurs.
# Le fichier ".env" ne doit JAMAIS être commité (il est dans .gitignore).
# ============================================================

# --- RPC (endpoints blockchain) ---
# Clé Alchemy gratuite sur alchemy.com — créer un compte et copier
# l'URL complète pour chaque réseau que tu veux utiliser.
# Tu peux laisser vide un réseau que tu n'utilises pas.
RPC_ETHEREUM=
RPC_ARBITRUM=
RPC_BASE=
RPC_OPT=
RPC_BNB=
RPC_MONAD=
RPC_PLASMA=
RPC_HYPERLIQUID=

# --- Garde-fous transaction / gas ---
# Garde-fou gas — ne pas dépasser ce montant par transaction
FEE_MAX_USD_PER_TX=0.50

# Marge de sécurité appliquée à l'estimation de gas (defi_fee_kit)
FEE_GAS_MARGIN=0.20

# Mode de calcul du prix du token natif pour l'estimation de fee (defi_fee_kit)
FEE_NATIVE_PRICE_MODE=hybrid

# Prix de secours du token natif en USD, utilisé si le mode hybride
# ne peut pas récupérer un prix live (defi_fee_kit)
BASE_NATIVE_USD=

# --- Thème UI (optionnel — valeurs par défaut si absent) ---
# Couleurs du thème (optionnel — valeurs par défaut si absent)
UI_ACCENT=
UI_VIOLET=
UI_YELLOW=
UI_PINK=
