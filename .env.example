# ============================================================
# PendleAPYito (PAO) — Template de configuration
# Copie ce fichier en ".env" puis remplis les valeurs.
# Le fichier ".env" ne doit JAMAIS être commité (il est dans .gitignore).
# ============================================================

# --- RPC (endpoints blockchain) les rpc préramplis ci-dessous sont public---
# Clé (rpc) Alchemy gratuite sur alchemy.com pour plus de fiabilité (privée)
# créer un compte et copier
# l'URL complète pour chaque réseau que tu veux utiliser.
#(endpoints publics gratuits — remplacer par Alchemy pour plus de fiabilité)
RPC_ETHEREUM=https://eth.llamarpc.com
RPC_ARBITRUM=https://arb1.arbitrum.io/rpc
RPC_BASE=https://mainnet.base.org
RPC_OPT=https://mainnet.optimism.io
RPC_BNB=https://bsc-dataseed.binance.org/
RPC_MONAD=https://rpc.monad.xyz
RPC_PLASMA=https://rpc.plasma.io
RPC_HYPERLIQUID=https://rpc.hyperliquid.xyz/evm

# --- Garde-fous transaction / gas ---
# Garde-fou gas — ne pas dépasser ce montant par transaction
FEE_MAX_USD_PER_TX=0.50

# Marge de sécurité appliquée à l'estimation de gas (defi_fee_kit)
FEE_GAS_MARGIN=0.20

# Mode de calcul du prix du token natif pour l'estimation de fee (defi_fee_kit)
FEE_NATIVE_PRICE_MODE=hybrid

# Prix de secours du token natif en USD, utilisé si le mode hybride
# ne peut pas récupérer un prix live (defi_fee_kit)
BASE_NATIVE_USD=

# --- Thème UI (optionnel — supprimer ces lignes pour garder le thème par défaut) ---
UI_ACCENT=rgba(56,189,248,0.95)
UI_VIOLET=rgba(168,85,247,0.92)
UI_YELLOW=rgba(245,158,11,0.92)
UI_PINK=rgba(244,114,182,0.92)